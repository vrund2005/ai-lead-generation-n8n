    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const data = item.json;\n\n  const companyName = data.companyName || data[\"Company Name\"] || '';\n  const email = data.email || data[\"Email\"] || '';\n  const website = data.website || data[\"Website\"] || '';\n\n  let domain = '';\n  let status = 'success';\n\n  try {\n    if (data.domain && typeof data.domain === 'string' && data.domain.trim()) {\n      domain = data.domain.trim().toLowerCase();\n    }\n    else if (email && typeof email === 'string' && email.includes('@')) {\n      domain = email.split('@')[1].trim().toLowerCase();\n    }\n    else if (website && typeof website === 'string' && website.trim()) {\n      let url = website.trim();\n\n      if (!url.match(/^https?:\\/\\//i)) {\n        url = 'https://' + url;\n      }\n\n      try {\n        const urlObj = new URL(url);\n        domain = urlObj.hostname.toLowerCase().replace(/^www\\./, '');\n      } catch {\n        domain = url.replace(/^https?:\\/\\/(www\\.)?/i, '').split('/')[0].toLowerCase();\n      }\n    }\n\n    if (!domain) {\n      status = 'no_domain_found';\n    }\n\n  } catch {\n    status = 'error';\n    domain = '';\n  }\n\n  results.push({\n    json: {\n      companyName,\n      email,\n      website,\n      domain,\n      status\n    }\n  });\n}\n\nreturn results;"
      },
