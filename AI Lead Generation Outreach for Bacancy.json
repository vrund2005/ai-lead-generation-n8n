    {
      "parameters": {
        "jsCode": "// Count total processed items, completed items, and skipped items from workflow execution\nconst allItems = $input.all();\n\n// Initialize counters\nlet totalProcessed = 0;\nlet completedItems = 0;\nlet skippedItems = 0;\n\n// Count items based on status\nfor (const item of allItems) {\n  totalProcessed++;\n  \n  const status = item.json.status || item.json.Status || '';\n  \n  if (status.toLowerCase() === 'completed') {\n    completedItems++;\n  } else if (status.toLowerCase().includes('error') || status.toLowerCase().includes('skip') || status.toLowerCase().includes('no_domain')) {\n    skippedItems++;\n  }\n}\n\n// Return summary statistics\nreturn [\n  {\n    json: {\n      totalProcessed: totalProcessed,\n      completedItems: completedItems,\n      skippedItems: skippedItems,\n      successRate: totalProcessed > 0 ? ((completedItems / totalProcessed) * 100).toFixed(2) + '%' : '0%',\n      timestamp: new Date().toISOString(),\n      workflowName: 'AI Lead Generation Outreach - Bacancy'\n    }\n  }\n];"
      },
